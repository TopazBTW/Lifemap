# Copy to .env — all values here are PUBLIC (inlined into the app bundle).
# Secrets (Gemini key, Mapbox sk.* download token, Instagram token) live in
# Cloud Functions Secret Manager / EAS secrets, never in EXPO_PUBLIC_*.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# pk.* public token (styles:read, fonts:read only)
EXPO_PUBLIC_MAPBOX_PUBLIC_TOKEN=pk.your_token

# Build-time only, used by the @rnmapbox/maps config plugin (sk.* with downloads:read).
# Set as an environment variable when running `npx expo prebuild` / EAS build:
# MAPBOX_DOWNLOAD_TOKEN=sk.your_token
