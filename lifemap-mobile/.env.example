# Copy to .env — all values here are PUBLIC (inlined into the app bundle).
# Secrets (the Gemini key) live in Cloud Functions, never in EXPO_PUBLIC_*.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Optional. Google Places (New) key for real establishment search + live photos.
# Restrict it to "Places API (New)" and set a daily quota cap in Google Cloud —
# it ships in the app bundle. Leave blank to fall back to free Nominatim +
# Wikipedia.
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
