{
  "expo": {
    "name": "LifeMap AI",
    "slug": "lifemap",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "lifemap",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "app.lifemap.mobile",
      "supportsTablet": false,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "app.lifemap.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#0A0E14",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0A0E14",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 96
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "LifeMap shows your position on your world map and tracks your runs."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "LifeMap attaches photos and videos to your memory capsules."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "LifeMap saves and reads memory media in your library.",
          "savePhotosPermission": "LifeMap saves exported memories to your library."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "LifeMap records voice notes for your memory capsules."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
